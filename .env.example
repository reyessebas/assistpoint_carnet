# ─────────────────────────────────────────────────────────────────────────────
# Assist Point — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Never commit a .env file with real secrets to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=production

# ── Authentication (REQUIRED in production) ───────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-secure-jwt-secret-here
ADMIN_PASSWORD=your-secure-admin-password-here

# ── MySQL Database (REQUIRED in production) ───────────────────────────────────
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=assist_point

# ── Admin Account ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@assistpoint.co

# ── Server / Networking ───────────────────────────────────────────────────────
# Railway injects PORT automatically — only set this locally if needed.
# PORT=3000
PUBLIC_APP_URL=https://your-app-domain.railway.app
CORS_ORIGINS=https://your-app-domain.railway.app

# ── Frontend ──────────────────────────────────────────────────────────────────
# Set to true to serve the compiled Angular frontend from the same Node process.
SERVE_FRONTEND=false

# ── HTTPS / TLS ───────────────────────────────────────────────────────────────
# Railway terminates TLS at the edge — keep USE_HTTPS=true so HSTS headers are sent.
USE_HTTPS=true
# TLS_KEY_PATH=./certs/key.pem
# TLS_CERT_PATH=./certs/cert.pem

# ── Token Expiry (optional — defaults shown) ──────────────────────────────────
# ACCESS_TOKEN_EXPIRES=900      # 15 minutes (seconds)
# REFRESH_TOKEN_EXPIRES=604800  # 7 days (seconds)

# ── Rate Limiting (optional — defaults shown) ─────────────────────────────────
# RATE_LIMIT_WINDOW=900   # 15 minutes (seconds)
# RATE_LIMIT_MAX=100      # max requests per window per IP

# ── MySQL Pool (optional — defaults shown) ────────────────────────────────────
# MYSQL_CONNECTION_LIMIT=10
