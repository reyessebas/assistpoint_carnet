# Server Configuration
PORT=3000
NODE_ENV=production
SERVE_FRONTEND=true
PUBLIC_APP_URL=https://yourdomain.com

# Data Configuration
DATA_DIR=./data
DATA_DB=mysql

# MySQL Configuration (use when DATA_DB=mysql)
MYSQL_HOST=your-mysql-host.example.com
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_strong_mysql_password
MYSQL_DATABASE=your_mysql_database
MYSQL_CONNECTION_LIMIT=10

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# JWT / Authentication
JWT_SECRET=replace_with_long_random_secret_min_32_chars
ACCESS_TOKEN_EXPIRES=900
REFRESH_TOKEN_EXPIRES=604800
ADMIN_EMAIL=admin@assistpoint.co
ADMIN_PASSWORD=replace_with_strong_admin_password

# Rate Limiting
RATE_LIMIT_WINDOW=900
RATE_LIMIT_MAX=100

# HTTPS/TLS (optional)
USE_HTTPS=false
TLS_KEY_PATH=./certs/key.pem
TLS_CERT_PATH=./certs/cert.pem
