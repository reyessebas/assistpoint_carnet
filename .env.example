# Assist Point - example environment variables
# Copy to .env only for local development. Never commit real .env files.

NODE_ENV=production
PORT=3000
SERVE_FRONTEND=true

# Public application URL used in generated carnet links and QR URLs.
PUBLIC_APP_URL=https://app.example.com
CORS_ORIGINS=https://app.example.com

# Authentication. Store real values in AWS Secrets Manager or SSM Parameter Store.
JWT_SECRET=replace_me_with_64_plus_random_chars
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_me_with_a_strong_password
ACCESS_TOKEN_EXPIRES=900
REFRESH_TOKEN_EXPIRES=604800

# MySQL. For AWS, prefer Amazon RDS MySQL or Aurora MySQL.
MYSQL_HOST=replace-me.cluster-xxxxxxxx.us-east-1.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_USER=assist_point_app
MYSQL_PASSWORD=replace_me
MYSQL_DATABASE=assist_point
MYSQL_CONNECTION_LIMIT=10

# Rate limiting.
RATE_LIMIT_WINDOW=900
RATE_LIMIT_MAX=100

# TLS is normally terminated by AWS load balancers/App Runner.
USE_HTTPS=false
# TLS_KEY_PATH=./certs/key.pem
# TLS_CERT_PATH=./certs/cert.pem
